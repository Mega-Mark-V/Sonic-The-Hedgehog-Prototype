Sections:
00: "org0001:0" (0-1F46)


Source: "mddr11.src"
                        	     1: ;=======================================================;
                        	     2: ;		    $$$DR.SRC  (Sound PCM Drum Control)				;
                        	     3: ;  						ORG. MDDR11.SRC						;
                        	     4: ;				'Sound-Source'								;
                        	     5: ;				 for Mega Drive (68K)						;
                        	     6: ;						Ver  1.1 / 1990.9.1				;
                        	     7: ;								      By  H.Kubota		;
                        	     8: ;=======================================================;
                        	     9: 
                        	    10: ;=======================================;
                        	    11: ;				 ASSIGN						;
                        	    12: ;=======================================;
                        	    13: ;----------------< I/O >----------------;
                        	    14: OPNADDRESS		EQU		4000H				; FM OPN1 address
                        	    15: OPNDATA				EQU		4001H				; FM data set address
                        	    16: BANKCHG				equ		6000H
                        	    17: 
                        	    18: ;----------------< RAM >----------------;
                        	    19: DR_REQ::		EQU		1FFFH				; REQUEST FLAG
                        	    20: REPEAT_FLG::		EQU		1FFEH				; REPEAT FLAG 1 := REPEAT / 
                        	    21: 										; 80H = REPEAT END / 0 = NO REPEAT
                        	    22: Z80_FLG				EQU		1FFDH
                        	    23: LOOP_DATA_STR		EQU		1FFCH				; LOOP START PCM DATA STORE (byte)
                        	    24: BANK_STORE::		equ		1FFAH				; 2 bytes  (high  ,low)
                        	    25: 										;		1ffah  |  1ffbh
                        	    26: 										;   a23-a16    | a15 0 0 0 0 0 0 0
                        	    27: VOICE_TB_ADR::		equ		1FF8H				; 2 bytes
                        	    28: VOICE_FLG		equ		1FF7H
                        	    29: USE_FLG				equ		1FF6H				; 68k use flag  80h = voice using
                        	    30: STACP::				EQU		1FF4H				; STAC BOTTOM
                        	    31: 
                        	    32: 
                        	    33: ;------------< FM CHIP I/O >------------;
                        	    34: DREG				EQU		2AH				; FM REG (PCM OUT)
                        	    35: DSEL				EQU		2BH				; FM REG (MODE SET)
                        	    36: 
                        	    37: ;------------< DATA OFFSET >------------;
                        	    38: TOP_ADR_OFS		equ		0				; data top adddress
                        	    39: HD_BYTE_OFS		equ		2				; data size
                        	    40: LOOP_FLG_OFS		equ		4				; loop flag
                        	    41: PRIORITY_OFS		equ		5				; priority
                        	    42: LOOP_BYTE_OFS		equ		6				; loop byte
                        	    43: END_BYTE_OFS		equ		8				; end byte
                        	    44: LPBASE_BYTE_OFS		equ		10				; dummy
                        	    45: DLY_DT_OFS		equ		11				; delay
                        	    46: 
                        	    47: LOW						equ		1EH				; MDT: redefined based on pre-compiled mddr11.hhh file
                        	    48: 
                        	    49: ;=======================================;
                        	    50: ;										;
                        	    51: ;				 START						;
                        	    52: ;										;
                        	    53: ;=======================================;
                        	    54: 
                        	    55: ;RYTHM_TB:						; drum data top address
                        	    56: 
                        	    57: ;-----------< USING REGISTOR >----------;
                        	    58: ;		 A : FM reg
                        	    59: ;		 C : FM data
                        	    60: ;		HL : FM i/o 
                        	    61: ;		IX : loop data store work point
                        	    62: ;		IY : data headder top point
                        	    63: ;		DE': data table pointer
                        	    64: ;		HL': dr_req
                        	    65: ;		BC': data bytes counter
                        	    66: 
                        	    67: ;=======================================;
                        	    68: ;				 START						;
                        	    69: ;=======================================;
                        	    70: 		ORG		0000H
                        	    71: 
00:0000 F3              	    72: 		DI								; interrupt disable
00:0001 F3              	    73: 		DI								; interrupt disable
00:0002 F3              	    74: 		DI								; interrupt disable
                        	    75: 
                        	    76: ;=======================================;
                        	    77: ;				INITIAL						;
                        	    78: ;=======================================;
00:0003 31F41F          	    79: 		LD		SP,STACP				; stack set
00:0006 AF              	    80: 		XOR		A
00:0007 32FD1F          	    81: 		LD		(Z80_FLG),A				; Z80 use flag clear
                        	    82: 
                        	    83: ;=======================================;
                        	    84: ;				BANK SET				;
                        	    85: ;=======================================;
                        	    86: BANKSET::
00:000A 3AFB1F          	    87: 		LD		A,(BANK_STORE+1)		; bank low data
00:000D 07              	    88: 		RLCA								; bit 0 = low data
00:000E 320060          	    89: 		LD		(BANKCHG),A				; low set
00:0011 0608            	    90: 		LD		B,8						; other bit total
00:0013 3AFA1F          	    91: 		LD		A,(BANK_STORE)				; bank high data
                        	    92: B_LOOP:
00:0016 320060          	    93: 		LD		(BANKCHG),A				; high set
00:0019 0F              	    94: 		RRCA
00:001A 10FA            	    95: 		DJNZ		B_LOOP
                        	    96: 
00:001C 1810            	    97: 		JR		START
                        	    98: ;=======================================;
                        	    99: ;		     PCM CHANGE TABLE				;
                        	   100: ;=======================================;
                        	   101: TO_PCM_TB::
00:001E 00              	   102: 		DB		+000H,+001H,+002H,+004H,+008H,+010H,+020H,+040H
00:001F 01
00:0020 02
00:0021 04
00:0022 08
00:0023 10
00:0024 20
00:0025 40
00:0026 80              	   103: 		DB		+080H,-001H,-002H,-004H,-008H,-010H,-020H,-040H
00:0027 FF
00:0028 FE
00:0029 FC
00:002A F8
00:002B F0
00:002C E0
00:002D C0
                        	   104: ;=======================================;
                        	   105: ;				MAIN LOOP				;
                        	   106: ;=======================================;
                        	   107: START:
00:002E 21FF1F          	   108: 		LD		HL,DR_REQ
                        	   109: ;===========  REQUEST CHECK  ===========;
                        	   110: DRST::
00:0031 7E              	   111: 		LD		A,(HL)						; A = request no.
00:0032 B7              	   112: 		OR		A						; if request = plus
00:0033 F23100          	   113: 		JP		P,DRST						; then jump
                        	   114: 
00:0036 F5              	   115: 		PUSH		AF
00:0037 E5              	   116: 		PUSH		HL
                        	   117: 
00:0038 3E80            	   118: 		LD		A,080H						;
00:003A 32FD1F          	   119: 		LD		(Z80_FLG),A				; Z80 use flag set
                        	   120: 
                        	   121: ;----------< FM D/A MODE SET >----------;
00:003D 210040          	   122: 		LD		HL,OPNADDRESS
00:0040 362B            	   123: 		LD		(HL),DSEL
00:0042 23              	   124: 		INC		HL
00:0043 77              	   125: 		LD		(HL),A						; 80h = D/A mode set data
                        	   126: 
00:0044 AF              	   127: 		XOR		A
00:0045 32FD1F          	   128: 		LD		(Z80_FLG),A				; flag set
                        	   129: 
                        	   130: ;------------< USE FLAG SET >-----------;
00:0048 2B              	   131: 		DEC		HL						; HL = OPNADDRESS
00:0049 DD21FC1F        	   132: 		LD		IX,LOOP_DATA_STR
00:004D 1600            	   133: 		LD		D,0
00:004F D9              	   134: 		EXX
00:0050 E1              	   135: 		POP		HL
00:0051 32F61F          	   136: 		LD		(USE_FLG),A
                        	   137: 
00:0054 F1              	   138: 		POP		AF
                        	   139: 
                        	   140: ;---------< REQUEST NO. CHECK >---------;
00:0055 32F71F          	   141: 		LD		(VOICE_FLG),A				; bit 7 = on then drum
00:0058 D681            	   142: 		SUB		81H
00:005A 77              	   143: 		LD		(HL),A
00:005B 110000          	   144: 		LD		DE,0
00:005E FD216301        	   145: 		LD		IY,RYTHM_TB
00:0062 FE06            	   146: 		CP		6						; if 7> then voice data req
00:0064 3810            	   147: 		JR		C,DRST_0
                        	   148: ;---------------< VOICE >---------------;
00:0066 32F71F          	   149: 		LD		(VOICE_FLG),A				; bit 7 = off then voice
00:0069 32F61F          	   150: 		LD		(USE_FLG),A				; voice using
00:006C FD2AF81F        	   151: 		LD		IY,(VOICE_TB_ADR)		; 
00:0070 ED5BF81F        	   152: 		LD		DE,(VOICE_TB_ADR)
00:0074 D607            	   153: 		SUB		7
                        	   154: DRST_0:
00:0076 87              	   155: 		ADD		A,A
00:0077 87              	   156: 		ADD		A,A						; a = a*4
00:0078 4F              	   157: 		LD		C,A						; c = a*4
00:0079 87              	   158: 		ADD		A,A						; a = a*8
00:007A 81              	   159: 		ADD		A,C						; a = a*12
                        	   160: 		
00:007B 4F              	   161: 		LD		C,A
00:007C 0600            	   162: 		LD		B,0
00:007E FD09            	   163: 		ADD		IY,BC						; iy = data headder top
                        	   164: 
                        	   165: ;----------< GET TOP ADDRESS >----------;
00:0080 FD5E00          	   166: 		LD		E,(IY+TOP_ADR_OFS)
00:0083 FD5601          	   167: 		LD		D,(IY+TOP_ADR_OFS+1)		; de = data top
00:0086 3AF71F          	   168: 		LD		A,(VOICE_FLG)
00:0089 B7              	   169: 		OR		A
00:008A FA9200          	   170: 		JP		M,GET_BYTE
00:008D 2AF81F          	   171: 		LD		HL,(VOICE_TB_ADR)
00:0090 19              	   172: 		ADD		HL,DE
00:0091 EB              	   173: 		EX		DE,HL						; de = data top (when voice)
                        	   174: 
                        	   175: GET_BYTE:
                        	   176: ;-----------< GET DATA SIZE >-----------;
00:0092 FD4E02          	   177: 		LD		C,(IY+HD_BYTE_OFS)
00:0095 FD4603          	   178: 		LD		B,(IY+HD_BYTE_OFS+1)		; bc = data bytes
                        	   179: ;-----------< GET LOOP FLAG >-----------;
00:0098 FD7E04          	   180: 		LD		A,(IY+LOOP_FLG_OFS)		; a = loop flag
00:009B 32FE1F          	   181: 		LD		(REPEAT_FLG),A				; (0 = no loop / 80h = loop)
                        	   182: 
00:009E D9              	   183: 		EXX
00:009F 0E80            	   184: 		LD		C,80H						; C = D/A start data
00:00A1 D9              	   185: 		EXX
                        	   186: 		
                        	   187: SPEECH::
00:00A2 21FF1F          	   188: 		LD		HL,DR_REQ
                        	   189: ;=======================================;
                        	   190: ;		       āfü[ā^ō]æŚ				;
                        	   191: ;=======================================;
                        	   192: ;----------< HIGH NIBLE DATA >----------;
00:00A5 1A              	   193: 		LD		A,(DE)						; get original 4 bit ADPCM data
00:00A6 E6F0            	   194: 		AND		$F0						; get 4 bit data ( H )
00:00A8 0F              	   195: 		RRCA
00:00A9 0F              	   196: 		RRCA
00:00AA 0F              	   197: 		RRCA
00:00AB 0F              	   198: 		RRCA								; HIGH NIBLE >> LOW NIBLE
                        	   199: 
                        	   200: 
00:00AC C61E            	   201: 		ADD		A,LOW TO_PCM_TB
                        	   202: ;-----------< ADPCM --> PCM >----------;
00:00AE D9              	   203: 		EXX								; HL = FM reg addr
                        	   204: 										; DE = table pointer
00:00AF 5F              	   205: 		LD		E,A						; de = TO_PCM_TB
00:00B0 1A              	   206: 		LD		A,(DE)						; get 8bit pcm data NO SA
00:00B1 81              	   207: 		ADD		A,C						; A = pcm data
                        	   208: ;=======================================;
                        	   209: ;      WRITE HIGH NIBLE DATA STO D/A		;
                        	   210: ;=======================================;
                        	   211: ;		A = data
00:00B2 4F              	   212: 		LD		C,A						; STORE DATA
                        	   213: 
00:00B3 3E80            	   214: 		LD		A,080H						;
00:00B5 32FD1F          	   215: 		LD		(Z80_FLG),A				; flag set
00:00B8 FD460B          	   216: 		LD		B,(IY+DLY_DT_OFS)		; b = DELY ( wait )
                        	   217: LOOP1:
00:00BB CB7E            	   218: 		BIT		7,(HL)						; opn busy check
00:00BD 20FC            	   219: 		JR		NZ,LOOP1
00:00BF 362A            	   220: 		LD		(HL),DREG				; HL = FM reg addr
00:00C1 23              	   221: 		INC		HL
00:00C2 AF              	   222: 		XOR		A						; a = clear data
00:00C3 71              	   223: 		LD		(HL),C
00:00C4 32FD1F          	   224: 		LD		(Z80_FLG),A				; flag clear
00:00C7 2B              	   225: 		DEC		HL
                        	   226: ;---------------< DELAY >---------------;
00:00C8 10FE            	   227: 		DJNZ		$
00:00CA D9              	   228: 		EXX
                        	   229: ;-----------< LOW NIBLE DATA >----------;
00:00CB 1A              	   230: 		LD		A,(DE)						; get original 4 bit ADPCM data
00:00CC E60F            	   231: 		AND		$0F						; get 4 bit data ( H )
                        	   232: 
00:00CE C61E            	   233: 		ADD		A,LOW TO_PCM_TB
                        	   234: 
00:00D0 D9              	   235: 		EXX
00:00D1 5F              	   236: 		LD		E,A						; de = TO_PCM_TB
00:00D2 1A              	   237: 		LD		A,(DE)						; get 8bit pcm data NO SA
00:00D3 81              	   238: 		ADD		A,C
                        	   239: 
                        	   240: ;=======================================;
                        	   241: ;      WRITE LOW NIBLE DATA STO D/A		;
                        	   242: ;=======================================;
00:00D4 4F              	   243: 		LD		C,A						; STORE DATA
                        	   244: 
00:00D5 3E80            	   245: 		LD		A,080H						;
00:00D7 32FD1F          	   246: 		LD		(Z80_FLG),A				; flag set
00:00DA FD460B          	   247: 		LD		B,(IY+DLY_DT_OFS)		; b = DELY (wait)
                        	   248: LOOP2:
00:00DD CB7E            	   249: 		BIT		7,(HL)						; opn busy check
00:00DF 20FC            	   250: 		JR		NZ,LOOP2
00:00E1 362A            	   251: 		LD		(HL),DREG				; HL = OPNADDRESS
00:00E3 23              	   252: 		INC		HL
00:00E4 AF              	   253: 		XOR		A						; clear data
00:00E5 71              	   254: 		LD		(HL),C
00:00E6 32FD1F          	   255: 		LD		(Z80_FLG),A				; flag clear
00:00E9 2B              	   256: 		DEC		HL
                        	   257: ;---------------< DELAY >---------------;
00:00EA 10FE            	   258: 		DJNZ		$
                        	   259: 
                        	   260: ;=======================================;
                        	   261: ;		      CHECK REQUEST				;
                        	   262: ;=======================================;
                        	   263: REQ_CHECK::
00:00EC D9              	   264: 		EXX
00:00ED FDCB057E        	   265: 		BIT		7,(IY+PRIORITY_OFS)		; if bit 7= on then 
00:00F1 2005            	   266: 		JR		NZ,NO_CHECK				;    req no no check
00:00F3 CB7E            	   267: 		BIT		7,(HL)						;  hl = dr_req
00:00F5 C23100          	   268: 		JP		NZ,DRST						;   new voice set
                        	   269: ;=======================================;
                        	   270: ;				NEXT LOOP				;
                        	   271: ;=======================================;
                        	   272: NO_CHECK::
00:00F8 13              	   273: 		INC		DE						; inc table pointer
00:00F9 0B              	   274: 		DEC		BC
00:00FA 79              	   275: 		LD		A,C
00:00FB B0              	   276: 		OR		B						; if DE = Z then 
00:00FC C2A200          	   277: 		JP		NZ,SPEECH
00:00FF 3AFE1F          	   278: 		LD		A,(REPEAT_FLG)
00:0102 B7              	   279: 		OR		A
00:0103 CA5601          	   280: 		JP		Z,PCM_END
                        	   281: 
00:0106 D9              	   282: 		EXX
00:0107 F20F01          	   283: 		JP		P,PCM_LOOP_GO
                        	   284: ;----------< REPEAT INITIAL >-----------;
                        	   285: PCM_LOOP_SET::
00:010A E67F            	   286: 		AND		7FH
00:010C DD7100          	   287: 		LD		(IX),C						; IX = LOOP_DATA_STR
                        	   288: PCM_LOOP_GO::
00:010F 3D              	   289: 		DEC		A
00:0110 32FE1F          	   290: 		LD		(REPEAT_FLG),A				; counter store
00:0113 2821            	   291: 		JR		Z,LOOP_END
00:0115 DD4E00          	   292: 		LD		C,(IX)						; IX = LOOP_DATA_STR
                        	   293: 
                        	   294: ;------< LOOP BYTE COUNTER MAKE >-------;
00:0118 D9              	   295: 		EXX
00:0119 FD6E06          	   296: 		LD		L,(IY+LOOP_BYTE_OFS)
00:011C FD6607          	   297: 		LD		H,(IY+LOOP_BYTE_OFS+1)		; hl = loop bytes
                        	   298: ;----------< GET REPEAT BYTE >----------;
                        	   299: 		;   hl + de*b  ( <loop bytes> + <loop base bytes> * < ran dam >
                        	   300: ADD_LOOP::
00:011F 44              	   301: 		LD		B,H
00:0120 4D              	   302: 		LD		C,L						; bc = loop byte
                        	   303: ;-------< LOOP START ADDRES GET >-------;
00:0121 FD5E00          	   304: 		LD		E,(IY+TOP_ADR_OFS)
00:0124 FD5601          	   305: 		LD		D,(IY+TOP_ADR_OFS+1)
00:0127 2AF81F          	   306: 		LD		HL,(VOICE_TB_ADR)
00:012A 19              	   307: 		ADD		HL,DE
                        	   308: 
00:012B FD5E02          	   309: 		LD		E,(IY+HD_BYTE_OFS)
00:012E FD5603          	   310: 		LD		D,(IY+HD_BYTE_OFS+1)
                        	   311: 
00:0131 19              	   312: 		ADD		HL,DE
00:0132 EB              	   313: 		EX		DE,HL						; DE = loop start addr
                        	   314: 
00:0133 C3A200          	   315: 		JP		SPEECH
                        	   316: 
                        	   317: ;=======================================;
                        	   318: ;										;
                        	   319: ;				LOOP END				;
                        	   320: ;										;
                        	   321: ;=======================================;
                        	   322: LOOP_END::
00:0136 DD4E00          	   323: 		LD		C,(IX)						; IX = LOOP_DATA_STR
00:0139 D9              	   324: 		EXX
00:013A FD4E08          	   325: 		LD		C,(IY+END_BYTE_OFS)
00:013D FD4609          	   326: 		LD		B,(IY+END_BYTE_OFS+1)
                        	   327: 
00:0140 FD6E02          	   328: 		LD		L,(IY+HD_BYTE_OFS)
00:0143 FD6603          	   329: 		LD		H,(IY+HD_BYTE_OFS+1)
00:0146 FD5E00          	   330: 		LD		E,(IY+TOP_ADR_OFS)
00:0149 FD5601          	   331: 		LD		D,(IY+TOP_ADR_OFS+1)		; offset adr add
00:014C 19              	   332: 		ADD		HL,DE
00:014D ED5BF81F        	   333: 		LD		DE,(VOICE_TB_ADR)
00:0151 19              	   334: 		ADD		HL,DE						; offset start addr add
00:0152 EB              	   335: 		EX		DE,HL						; DE = start addr
00:0153 C3A200          	   336: 		JP		SPEECH
                        	   337: 
                        	   338: ;=======================================;
                        	   339: ;										;
                        	   340: ;				 PCM END				;
                        	   341: ;										;
                        	   342: ;=======================================;
                        	   343: PCM_END::
00:0156 21F61F          	   344: 		LD		HL,USE_FLG
00:0159 7E              	   345: 		LD		A,(HL)
00:015A B7              	   346: 		OR		A						; if voice sat then pls
00:015B FA2E00          	   347: 		JP		M,START
00:015E AF              	   348: 		XOR		A
00:015F 77              	   349: 		LD		(HL),A						; use flag clear
00:0160 C32E00          	   350: 		JP		START
                        	   351: 
                        	   352: 		INCLUDE				"mddt11.src"		;		MDT: added since we're not using a makefile

Source: "mddt11.src"
                        	     1: ;=======================================================;
                        	     2: ;		    $$$DT.SRC  (Sound PCM Drum Data)				;
                        	     3: ;  						ORG. MDDT11.SRC						;
                        	     4: ;				'Sound-Source'								;
                        	     5: ;				 for Mega Drive (68K)						;
                        	     6: ;						Ver  1.1 / 1990.9.1				;
                        	     7: ;								      By  H.Kubota		;
                        	     8: ;=======================================================;
                        	     9: 
                        	    10: ;=======================================;
                        	    11: ;				 ASSIGN						;
                        	    12: ;=======================================;
                        	    13: ;---------------< FLAG >----------------;
                        	    14: NO_LOOP				EQU		0
                        	    15: LOOP				EQU		80H
                        	    16: NO_PRIORITY		EQU		0
                        	    17: PRIORITY		EQU		80H
                        	    18: 
                        	    19: ;---------------< DELAY >---------------;
                        	    20: BD_DL				EQU		08H
                        	    21: SNR_DL				EQU		16H
                        	    22: HCL_DL				EQU		17H
                        	    23: OHI_DL				EQU		01H
                        	    24: TOM_DL				EQU		0AH
                        	    25: 
                        	    26: ;=======================================;
                        	    27: ;										;
                        	    28: ;				DRUM DATA				;
                        	    29: ;										;
                        	    30: ;=======================================;
                        	    31: 
                        	    32: ;		PUBLIC		RYTHM_TB
                        	    33: 
                        	    34: RYTHM_TB::
                        	    35: ;=======================================;
                        	    36: ;				 HEADDER				;
                        	    37: ;=======================================;
                        	    38: 
                        	    39: ;==============< BASS DRUM >============;
00:0163 9F01            	    40: BD_TB::				DW		BDTOP				; data address top
00:0165 5203            	    41: 				DW		SNRTOP-BDTOP		; data size
00:0167 00              	    42: 				DB		NO_LOOP				; loop flag
